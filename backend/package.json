{
  "name": "setnote-backend",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "build:lambda": "npx esbuild src/lambda.ts --bundle --platform=node --target=node24 --outfile=dist/lambda.js --external:@aws-sdk/*",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.700.0",
    "@aws-sdk/lib-dynamodb": "^3.700.0",
    "@hono/node-server": "^2.0.8",
    "hono": "^4.12.28",
    "nanoid": "^5.0.9"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "esbuild": "^0.24.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  }
}
